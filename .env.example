# Seki Agent backend settings
SEKI_APP_NAME="Seki Agent API"
SEKI_APP_VERSION="0.1.0"
SEKI_DEBUG=false
SEKI_API_V1_PREFIX="/api/v1"

# Runtime data paths inside Docker Compose.
SEKI_DATA_DIR="/app/data"
SEKI_DATABASE_PATH="/app/data/db/seki_agent.db"
SEKI_WORKSPACE_DIR="/app/data/workspace"
SEKI_DIFF_WORK_DIR="/app/data/diff_work"
SEKI_SPI_WORK_DIR="/app/data/spi_work"
SEKI_TRANSLATION_WORK_DIR="/app/data/translation_work"
SEKI_SKILLS_DIR="/app/data/skills"
SEKI_LEGACY_SRC_DIR="/app/backend/legacy"

# Change this in any non-local environment.
SEKI_TOKEN_SECRET_KEY="change-me"
SEKI_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# RAG / model settings.
# Configure model keys in backend environment variables. The frontend does not collect API keys.
# SEKI_RAG_API_KEY=""
SEKI_RAG_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
SEKI_RAG_MODEL_NAME="qwen-plus"
# Web search uses the Volc/Feedcoop-compatible provider when a key is available
# here.
# SEKI_WEB_SEARCH_API_KEY=""
SEKI_WEB_SEARCH_API_URL="https://open.feedcoopapi.com/search_api/web_search"
SEKI_WEB_SEARCH_TIMEOUT_SECONDS=30
SEKI_WEB_SEARCH_MAX_SUMMARY_CHARS=4000
SEKI_TASK_EXECUTOR="sync"
SEKI_TASK_EXECUTOR_MAX_WORKERS=3

# Code agent settings. Arbitrary shell is still disabled. The agent can delete
# files/directories under the current user's workspace; project root and skills
# remain read-only.
# Defaults to project root + workspace + shared skills dir when omitted.
# SEKI_CODE_AGENT_ALLOWED_ROOTS='["/app","/app/data/workspace","/app/data/skills"]'
# Sensitive files such as .env, private keys and DB files are blocked in service policy.
SEKI_CODE_AGENT_MAX_READ_BYTES=1048576
SEKI_CODE_AGENT_MAX_WRITE_BYTES=1048576
# Extra direct-execute command prefixes for code agent. Keep this narrow.
# Example: SEKI_CODE_AGENT_ALLOWED_COMMAND_PREFIXES='["ruff check","npm test"]'
SEKI_CODE_AGENT_ALLOWED_COMMAND_PREFIXES='[]'
# Command prefixes that require frontend confirmation before execution.
# Example: SEKI_CODE_AGENT_CONFIRMED_COMMAND_PREFIXES='["python --version"]'
SEKI_CODE_AGENT_CONFIRMED_COMMAND_PREFIXES='[]'
SEKI_RUN_LIVE_AGENT_TESTS=false
SEKI_CORS_ORIGINS='["http://127.0.0.1:5173","http://localhost:5173"]'

# Legacy translator settings read by src/translate_text.py.
# Configure translator keys in backend environment variables. The frontend does not collect API keys.
# TRANSLATE_API_KEY=""
TRANSLATE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
TRANSLATE_LLM_MODEL="qwen-plus"
TRANSLATE_DELAY=1.2

# LangSmith tracing for LangChain/LangGraph.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=""
# LANGSMITH_PROJECT="seki-agent-local"
